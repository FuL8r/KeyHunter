# Конфигурация vulnrag.
# Скопируй в .env и при необходимости поменяй значения:
#   cp .env.example .env
#
# .env читается автоматически (Settings, префикс VULNRAG_).
# Реальные переменные окружения имеют приоритет над .env, напр.:
#   VULNRAG_NVD_START_DATE=2026-03-15T00:00:00 ./run.sh sync
#
# Все поля опциональны — без .env берутся значения по умолчанию (ниже в комментариях).

# --- Источник NVD ---
# С какой даты тянуть NVD при ПЕРВОМ бэкафилле (когда нет sync_state.json).
# Узкое окно = быстрее. Полный корпус: 2019-01-01 (по умолчанию, это часы).
#VULNRAG_NVD_START_DATE=2019-01-01

# Ключ NVD API (поднимает лимит запросов ~в 6 раз). Получить:
# https://nvd.nist.gov/developers/request-an-api-key
#VULNRAG_NVD_API_KEY=

# --- Qdrant ---
#VULNRAG_QDRANT_HOST=localhost
#VULNRAG_QDRANT_PORT=6333
#VULNRAG_COLLECTION=vulnerabilities

# --- Модели (Ollama) ---
#VULNRAG_EMBED_MODEL=bge-m3
#VULNRAG_EMBED_DIM=1024
#VULNRAG_LLM_MODEL=qwen2.5:3b
#VULNRAG_OLLAMA_HOST=http://localhost:11434

# --- Поиск / прочее ---
#VULNRAG_TOP_K=8
#VULNRAG_SYNC_STATE_PATH=sync_state.json
